{
  "name": "issue-foundry",
  "version": "2.0.5",
  "type": "module",
  "description": "MCP server plugin for managing kanban boards, issues, and documents",
  "bin": {
    "issue-foundry": "dist/server/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/server.js",
    "dev": "tsx watch src/server.ts",
    "mcp": "node dist/server/index.js",
    "mcp:dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.19.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3"
  }
}
