{
  "name": "issue-foundry",
  "version": "2.0.5",
  "description": "Kanban board for AI agents — manage issues, comments, and documents scoped to your project",
  "author": {
    "name": "HgGamer"
  },
  "repository": "https://github.com/HgGamer/IssueFoundry",
  "license": "MIT",
  "keywords": ["kanban", "issues", "project-management", "mcp"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/setup.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/teardown.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
